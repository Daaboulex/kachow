  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/auto-pull-global.js\"",
            "timeout": 20,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-context-loader.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-start-combined.js\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-presence-start.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/plugin-update-checker.js\"",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-upstream-checker.js\"",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/tool-parity-check.js\"",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/handoff-triage-gate.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/per-prompt-overhead.js\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-presence-track.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "Bash|Edit|Glob|Grep|MultiEdit|Read|TodoWrite|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/bandaid-loop-detector.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/context-pressure-enforce.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Bash|Edit|MultiEdit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/todowrite-mirror.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "TodoWrite|write_todos"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-write-sync.js\"",
            "timeout": 5,
            "if": "Write(*.claude/*)|Write(*.gemini/*)|Write(*CLAUDE.md)|Write(*GEMINI.md)|Write(*.ai-context/*)|Edit(*.claude/*)|Edit(*.gemini/*)|Edit(*CLAUDE.md)|Edit(*GEMINI.md)|Edit(*.ai-context/*)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-invocation-logger.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "Bash|Skill"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/memory-retrieval-logger.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "Bash|Read"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-drift-guard.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Bash|Edit|Glob|Grep|Read|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/rule-enforcement-check.js\"",
            "timeout": 5,
            "async": true
          }
        ],
        "matcher": "Agent|Skill"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-completion-correlator.js\"",
            "timeout": 5,
            "async": true
          }
        ],
        "matcher": "Bash|Edit|Skill|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/research-lint.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Edit|MultiEdit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/handoff-auto-save.js\"",
            "timeout": 5,
            "async": true
          }
        ],
        "matcher": "Bash|Edit|MultiEdit|TaskCreate|TaskUpdate|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/block-subagent-writes.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/verifiedby-gate.js\"",
            "timeout": 3
          }
        ],
        "matcher": "TodoWrite|write_todos"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/autosave-before-destructive.js\"",
            "timeout": 8,
            "if": "Bash(rm *) OR Bash(git reset*) OR Bash(git clean*) OR Bash(git checkout -- *)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/peer-conflict-check.js\"",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pre-write-combined-guard.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Bash|Edit|MultiEdit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/scrub-sentinel.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Edit|MultiEdit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/prefer-editing-nudge.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/block-subagent-non-bash-writes.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Edit|MultiEdit|NotebookEdit|Write|mcp__.*"
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/tool-parity-check.js\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-presence-end.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/todowrite-persist.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/reflect-stop.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/dream-auto.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/auto-push-global.js\"",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/track-skill-usage.js\"",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/stop-sleep-consolidator.js\"",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/meta-system-stop.js\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-auto-updater.js\"",
            "timeout": 30,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/memory-rotate.js\"",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-end-logger.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/handoff-session-end.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/prompt-item-tracker.js\"",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/prompt-clarity-check.js\"",
            "timeout": 3,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/slash-command-logger.js\"",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/notify-with-fallback.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/sub[agent-skill]-inject.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/subagent-quality-gate.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/task-verification-gate.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/reflect-precompact.js\"",
            "timeout": 5
          }
        ],
        "matcher": "auto|manual"
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/memory-post-compact.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/cwd-changed-watcher.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/file-changed-notify.js\"",
            "timeout": 3
          }
        ],
        "matcher": ".envrc|AGENTS.md|CLAUDE.md|GEMINI.md"
      }
    ]
  }
}