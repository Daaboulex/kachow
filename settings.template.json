  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/hooks/enhanced-statusline.js\""
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/auto-pull-global.js\"",
            "timeout": 20
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/plugin-update-checker.js\"",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-start-combined.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-context-loader.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-upstream-checker.js\"",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-presence-start.js\"",
            "timeout": 3
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/validate-instructions-sync.js\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-presence-track.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "Write|Edit|MultiEdit|Bash|Read|Grep|Glob|TodoWrite"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/bandaid-loop-detector.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-drift-guard.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "Bash|Edit|Write|Read|Grep|Glob"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/todowrite-mirror.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "TodoWrite"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/context-pressure-enforce.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Write|Edit|MultiEdit|Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-write-sync.js\"",
            "if": "Write(*.claude/*)|Write(*.gemini/*)|Write(*CLAUDE.md)|Write(*GEMINI.md)|Write(*.ai-context/*)|Edit(*.claude/*)|Edit(*.gemini/*)|Edit(*CLAUDE.md)|Edit(*GEMINI.md)|Edit(*.ai-context/*)",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-invocation-logger.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "Skill"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-doc-drift-detector.js\"",
            "if": "Write(*.claude/hooks/*.js)",
            "timeout": 5
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-doc-drift-detector.js\"",
            "if": "Edit(*.claude/hooks/*.js)",
            "timeout": 5
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/dead-hook-detector.js\"",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/memory-retrieval-logger.js\"",
            "timeout": 3,
            "async": true
          }
        ],
        "matcher": "Read"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/research-lint.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/notify-with-fallback.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/verifiedby-gate.js\"",
            "timeout": 3
          }
        ],
        "matcher": "TodoWrite"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/validate-settings-on-write.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/prefer-editing-nudge.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/block-subagent-writes.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pre-write-combined-guard.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/autosave-before-destructive.js\"",
            "timeout": 8
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pre-write-combined-guard.js\"",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/halt-condition-validator.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Skill"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/doc-shard-resolver.js\"",
            "timeout": 3
          }
        ],
        "matcher": "Read"
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/subagent-harness-inject.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/subagent-quality-gate.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/task-verification-gate.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-presence-end.js\"",
            "timeout": 3
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/todowrite-persist.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/reflect-stop.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/dream-auto.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/memory-rotate.js\"",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/auto-push-global.js\"",
            "timeout": 20,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/track-skill-usage.js\"",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/meta-system-stop.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/stop-sleep-consolidator.js\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/reflect-precompact.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
